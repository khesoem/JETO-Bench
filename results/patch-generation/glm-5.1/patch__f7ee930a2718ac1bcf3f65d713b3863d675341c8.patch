+    private WrapperClusterEvent extractWrapperClusterEvent(ClientCacheEntryCustomEvent<byte[]> event) throws IOException, ClassNotFoundException {
+        ByteBuffer rawData = ByteBuffer.wrap(event.getEventData());
+
+        // skip the key, we don't need it
+        skipElement(rawData);
+
+        // read the value
+        Object value = marshaller.objectFromByteBuffer(readElement(rawData));
+        return value instanceof WrapperClusterEvent wce ? wce : null;
+    }
