+    private static FileObjectMeta createFileObjectMetaFromSummary(final S3BucketKey s3Object,
+                                                                   final S3ObjectSummary s3ObjectSummary) {
+
+        final HashMap<String, Object> userDefinedMetadata = new HashMap<>();
+
+        userDefinedMetadata.put("s3.object.summary.bucketName", s3Object.bucketName());
+        userDefinedMetadata.put("s3.object.summary.key", s3Object.key());
+        userDefinedMetadata.put("s3.object.summary.etag", s3ObjectSummary.getETag());
+        userDefinedMetadata.put("s3.object.summary.storageClass", s3ObjectSummary.getStorageClass());
+
+        final String eTag = s3ObjectSummary.getETag();
+
+        FileObjectMeta.ContentDigest digest = null;
+        if (eTag != null) {
+            // ETag for simple uploads is the MD5 hash of the object content, enclosed in double quotes.
+            // For multipart uploads, the ETag is not the MD5 hash, but it can still be used as a digest.
+            // Remove surrounding quotes if present.
+            String etagValue = eTag;
+            if (eTag.startsWith("\"") && eTag.endsWith("\"")) {
+                etagValue = eTag.substring(1, eTag.length() - 1);
+            }
+            digest = new FileObjectMeta.ContentDigest(etagValue, "MD5");
+        }
+
+        return new GenericFileObjectMeta.Builder()
+                .withUri(s3Object.toURI())
+                .withName(s3Object.key())
+                .withContentLength(s3ObjectSummary.getSize())
+                .withLastModified(s3ObjectSummary.getLastModified())
+                .withContentDigest(digest)
+                .withUserDefinedMetadata(userDefinedMetadata)
+                .build();
     }
