     /**
+     * Create a {@link FileObjectMeta} from an {@link S3ObjectSummary} without making additional API calls.
+     * This is used for listing objects to avoid extra metadata requests.
+     *
+     * @param objectSummary the S3 object summary.
+     * @return a new {@link FileObjectMeta}.
+     */
+    public FileObjectMeta createFileObjectMeta(final S3ObjectSummary objectSummary) {
+        final S3BucketKey s3Object = new S3BucketKey(
+                objectSummary.getBucketName(),
+                objectSummary.getKey()
+        );
+
+        final HashMap<String, Object> userDefinedMetadata = new HashMap<>();
+        userDefinedMetadata.put("s3.object.summary.bucketName", objectSummary.getBucketName());
+        userDefinedMetadata.put("s3.object.summary.key", objectSummary.getKey());
+        userDefinedMetadata.put("s3.object.summary.etag", objectSummary.getETag());
+        userDefinedMetadata.put("s3.object.summary.storageClass", objectSummary.getStorageClass());
+
+        // Use ETag as content digest (MD5 is not available in S3ObjectSummary)
+        FileObjectMeta.ContentDigest digest = null;
+        final String eTag = objectSummary.getETag();
+        if (eTag != null) {
+            digest = new FileObjectMeta.ContentDigest(eTag, "ETAG");
+        }
+
+        return new GenericFileObjectMeta.Builder()
+                .withUri(s3Object.toURI())
+                .withName(s3Object.key())
+                .withContentLength(objectSummary.getSize())
+                .withLastModified(objectSummary.getLastModified())
+                .withContentDigest(digest)
+                .withUserDefinedMetadata(userDefinedMetadata)
+                .build();
+    }
