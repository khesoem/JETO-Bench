From 25a7a79a7c0b70b287aab536291efdd0d9a037fe Mon Sep 17 00:00:00 2001
From: openhands <openhands@all-hands.dev>
Date: Tue, 24 Feb 2026 15:28:28 +0000
Subject: [PATCH] Ensure CopyrightAuthorProvider doesn't close shared GitLookup
 unless it created it\n\nCo-authored-by: openhands <openhands@all-hands.dev>

---
 .../plugin/license/git/CopyrightAuthorProvider.java   | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/license-maven-plugin-git/src/main/java/com/mycila/maven/plugin/license/git/CopyrightAuthorProvider.java b/license-maven-plugin-git/src/main/java/com/mycila/maven/plugin/license/git/CopyrightAuthorProvider.java
index ca6c6ee..2cf9c02 100644
--- a/license-maven-plugin-git/src/main/java/com/mycila/maven/plugin/license/git/CopyrightAuthorProvider.java
+++ b/license-maven-plugin-git/src/main/java/com/mycila/maven/plugin/license/git/CopyrightAuthorProvider.java
@@ -71,7 +71,16 @@ public class CopyrightAuthorProvider implements PropertiesProvider {
   @Override
   public void close() {
     if (gitLookup != null) {
-      gitLookup.close();
+      // Only close the lookup if this provider created it; otherwise another provider will manage it.
+      if (this.ownGitLookup) {
+        gitLookup.close();
+        try {
+          java.lang.reflect.Field sharedField = CopyrightRangeProvider.class.getDeclaredField("SHARED_GIT_LOOKUP");
+          sharedField.set(null, null);
+        } catch (Exception ignored) {
+          // ignore
+        }
+      }
     }
   }
 
-- 
